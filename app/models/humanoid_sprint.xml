<!--
  Simplified humanoid MJCF for sprint kinematic/kinetic analysis.
  Uses mocap bodies for BlazePose landmark tracking.
  Joint limits based on biomechanical ranges for sprinting.
-->
<mujoco model="humanoid_sprint">
  <compiler angle="radian" autolimits="true"/>

  <option timestep="0.002" integrator="implicit" gravity="0 0 -9.81">
    <flag contact="enable"/>
  </option>

  <default>
    <joint damping="5" armature="0.1" limited="true"/>
    <geom type="capsule" contype="1" conaffinity="1" friction="1 0.005 0.001"
          rgba="0.7 0.7 0.7 1" margin="0.001"/>
    <motor ctrllimited="true"/>
  </default>

  <asset>
    <texture type="2d" name="grid" builtin="checker" width="512" height="512"
             rgb1="0.1 0.1 0.1" rgb2="0.2 0.2 0.2"/>
    <material name="grid" texture="grid" texrepeat="8 8"/>
  </asset>

  <worldbody>
    <light directional="true" diffuse="0.8 0.8 0.8" pos="0 0 5" dir="0 0 -1"/>
    <geom name="floor" type="plane" size="50 50 0.1" material="grid" conaffinity="1"/>

    <!-- Pelvis / root body -->
    <body name="pelvis" pos="0 0 0.95">
      <freejoint name="root"/>
      <geom name="pelvis_geom" fromto="-.1 0 0 .1 0 0" size="0.08"/>
      <site name="left_hip_site" pos="-0.1 0 0"/>
      <site name="right_hip_site" pos="0.1 0 0"/>

      <!-- Torso -->
      <body name="torso" pos="0 0 0">
        <joint name="torso_flexion" type="hinge" axis="1 0 0" range="-0.5 0.8"/>
        <joint name="torso_lateral" type="hinge" axis="0 1 0" range="-0.3 0.3"/>
        <joint name="torso_rotation" type="hinge" axis="0 0 1" range="-0.8 0.8"/>
        <geom name="torso_geom" fromto="0 0 0 0 0 0.42" size="0.09"/>

        <!-- Left Shoulder -->
        <body name="left_upper_arm" pos="-0.19 0 0.42">
          <site name="left_shoulder_site" pos="0 0 0"/>
          <joint name="left_shoulder_flexion" type="hinge" axis="1 0 0" range="-2.6 0.8"/>
          <joint name="left_shoulder_abduction" type="hinge" axis="0 1 0" range="-0.3 3.1"/>
          <geom name="left_upper_arm_geom" fromto="0 0 0 0 0 -0.28" size="0.04"/>

          <body name="left_forearm" pos="0 0 -0.28">
            <site name="left_elbow_site" pos="0 0 0"/>
            <joint name="left_elbow_flexion" type="hinge" axis="1 0 0" range="-2.7 0"/>
            <geom name="left_forearm_geom" fromto="0 0 0 0 0 -0.25" size="0.03"/>
            <site name="left_wrist_site" pos="0 0 -0.25"/>
          </body>
        </body>

        <!-- Right Shoulder -->
        <body name="right_upper_arm" pos="0.19 0 0.42">
          <site name="right_shoulder_site" pos="0 0 0"/>
          <joint name="right_shoulder_flexion" type="hinge" axis="1 0 0" range="-2.6 0.8"/>
          <joint name="right_shoulder_abduction" type="hinge" axis="0 1 0" range="-3.1 0.3"/>
          <geom name="right_upper_arm_geom" fromto="0 0 0 0 0 -0.28" size="0.04"/>

          <body name="right_forearm" pos="0 0 -0.28">
            <site name="right_elbow_site" pos="0 0 0"/>
            <joint name="right_elbow_flexion" type="hinge" axis="1 0 0" range="-2.7 0"/>
            <geom name="right_forearm_geom" fromto="0 0 0 0 0 -0.25" size="0.03"/>
            <site name="right_wrist_site" pos="0 0 -0.25"/>
          </body>
        </body>
      </body>

      <!-- Left Leg -->
      <body name="left_thigh" pos="-0.1 0 0">
        <joint name="left_hip_flexion" type="hinge" axis="1 0 0" range="-0.4 2.1"/>
        <joint name="left_hip_abduction" type="hinge" axis="0 1 0" range="-0.5 0.3"/>
        <geom name="left_thigh_geom" fromto="0 0 0 0 0 -0.40" size="0.055"/>

        <body name="left_shank" pos="0 0 -0.40">
          <site name="left_knee_site" pos="0 0 0"/>
          <joint name="left_knee_flexion" type="hinge" axis="1 0 0" range="-2.6 0"/>
          <geom name="left_shank_geom" fromto="0 0 0 0 0 -0.38" size="0.04"/>

          <body name="left_foot" pos="0 0 -0.38">
            <site name="left_ankle_site" pos="0 0 0"/>
            <joint name="left_ankle_flexion" type="hinge" axis="1 0 0" range="-0.8 0.7"/>
            <geom name="left_foot_geom" fromto="0 -0.05 0 0 0.12 0" size="0.03"/>
          </body>
        </body>
      </body>

      <!-- Right Leg -->
      <body name="right_thigh" pos="0.1 0 0">
        <joint name="right_hip_flexion" type="hinge" axis="1 0 0" range="-0.4 2.1"/>
        <joint name="right_hip_abduction" type="hinge" axis="0 1 0" range="-0.3 0.5"/>
        <geom name="right_thigh_geom" fromto="0 0 0 0 0 -0.40" size="0.055"/>

        <body name="right_shank" pos="0 0 -0.40">
          <site name="right_knee_site" pos="0 0 0"/>
          <joint name="right_knee_flexion" type="hinge" axis="1 0 0" range="-2.6 0"/>
          <geom name="right_shank_geom" fromto="0 0 0 0 0 -0.38" size="0.04"/>

          <body name="right_foot" pos="0 0 -0.38">
            <site name="right_ankle_site" pos="0 0 0"/>
            <joint name="right_ankle_flexion" type="hinge" axis="1 0 0" range="-0.8 0.7"/>
            <geom name="right_foot_geom" fromto="0 -0.05 0 0 0.12 0" size="0.03"/>
          </body>
        </body>
      </body>
    </body>

    <!-- Mocap bodies for BlazePose landmark targets -->
    <body name="mocap_left_shoulder" mocap="true"><geom type="sphere" size="0.02" rgba="1 0 0 0.5" contype="0" conaffinity="0"/></body>
    <body name="mocap_right_shoulder" mocap="true"><geom type="sphere" size="0.02" rgba="1 0 0 0.5" contype="0" conaffinity="0"/></body>
    <body name="mocap_left_elbow" mocap="true"><geom type="sphere" size="0.02" rgba="0 1 0 0.5" contype="0" conaffinity="0"/></body>
    <body name="mocap_right_elbow" mocap="true"><geom type="sphere" size="0.02" rgba="0 1 0 0.5" contype="0" conaffinity="0"/></body>
    <body name="mocap_left_wrist" mocap="true"><geom type="sphere" size="0.02" rgba="0 0 1 0.5" contype="0" conaffinity="0"/></body>
    <body name="mocap_right_wrist" mocap="true"><geom type="sphere" size="0.02" rgba="0 0 1 0.5" contype="0" conaffinity="0"/></body>
    <body name="mocap_left_hip" mocap="true"><geom type="sphere" size="0.02" rgba="1 1 0 0.5" contype="0" conaffinity="0"/></body>
    <body name="mocap_right_hip" mocap="true"><geom type="sphere" size="0.02" rgba="1 1 0 0.5" contype="0" conaffinity="0"/></body>
    <body name="mocap_left_knee" mocap="true"><geom type="sphere" size="0.02" rgba="0 1 1 0.5" contype="0" conaffinity="0"/></body>
    <body name="mocap_right_knee" mocap="true"><geom type="sphere" size="0.02" rgba="0 1 1 0.5" contype="0" conaffinity="0"/></body>
    <body name="mocap_left_ankle" mocap="true"><geom type="sphere" size="0.02" rgba="1 0 1 0.5" contype="0" conaffinity="0"/></body>
    <body name="mocap_right_ankle" mocap="true"><geom type="sphere" size="0.02" rgba="1 0 1 0.5" contype="0" conaffinity="0"/></body>
  </worldbody>

  <actuator>
    <motor joint="torso_flexion" ctrlrange="-200 200"/>
    <motor joint="torso_lateral" ctrlrange="-100 100"/>
    <motor joint="torso_rotation" ctrlrange="-100 100"/>
    <motor joint="left_shoulder_flexion" ctrlrange="-80 80"/>
    <motor joint="left_shoulder_abduction" ctrlrange="-50 50"/>
    <motor joint="left_elbow_flexion" ctrlrange="-60 60"/>
    <motor joint="right_shoulder_flexion" ctrlrange="-80 80"/>
    <motor joint="right_shoulder_abduction" ctrlrange="-50 50"/>
    <motor joint="right_elbow_flexion" ctrlrange="-60 60"/>
    <motor joint="left_hip_flexion" ctrlrange="-300 300"/>
    <motor joint="left_hip_abduction" ctrlrange="-100 100"/>
    <motor joint="left_knee_flexion" ctrlrange="-300 300"/>
    <motor joint="left_ankle_flexion" ctrlrange="-150 150"/>
    <motor joint="right_hip_flexion" ctrlrange="-300 300"/>
    <motor joint="right_hip_abduction" ctrlrange="-100 100"/>
    <motor joint="right_knee_flexion" ctrlrange="-300 300"/>
    <motor joint="right_ankle_flexion" ctrlrange="-150 150"/>
  </actuator>
</mujoco>
